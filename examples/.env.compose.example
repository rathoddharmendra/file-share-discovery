# Copy this file to .env for docker compose.

# Isilon API credentials (required)
ISILON_USERNAME=svc_discovery
ISILON_PASSWORD=CHANGE_ME
ISILON_VERIFY_SSL=false

# Discovery runtime
INVENTORY_PATH=/workspace/config/inventory.yaml
DISCOVERY_INTERVAL_SECONDS=900

# Web app + LDAP/AD
FLASK_SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING
AD_SERVER=ldap://dc01.corp.local
AD_DOMAIN=CORP
AD_BASE_DN=DC=corp,DC=local
AD_ADMIN_GROUP=CN=NAS-Admins,OU=Groups,DC=corp,DC=local

# Optional Graph settings for the ps profile
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
