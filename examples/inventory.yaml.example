# inventory.yaml — non-secret node configuration
# Copy to inventory.yaml and edit. Do NOT store credentials here.

nodes:
  - name: isilon-prod-1
    host: 192.168.10.10
    port: 8080
    access_zones:
      - System
      - Finance
    share_types:
      - smb
      - nfs
    enabled: true

  - name: isilon-prod-2
    host: 192.168.10.11
    port: 8080
    access_zones:
      - System
      - HR
    share_types:
      - smb
    enabled: true

settings:
  db_path: ./shares.db
  snapshot_dir: ./snapshots
  concurrency: 10          # max simultaneous async API calls per node
  request_timeout_s: 30

